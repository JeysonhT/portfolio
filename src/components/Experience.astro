---
const experiences = [
  {
    company: "Autonomo",
    position: "Desarrollador Web Y Movil",
    date: "Abril 2026 - Actualidad",
    location: "Boaco, Nicaragua",
    skills: [
      "React Native",
      "React",
      "Context API",
      "Zustand",
      "PostgreSQL",
      "Supabase",
      "Java",
      "JavaFX",
      "MySql",
      "Astro",
    ],
    github: [
      "https://github.com/JeysonhT/Cheaps",
      "https://github.com/JeysonhT/MicroPOS",
      "https://github.com/JeysonhT/portfolio",
    ],
    description:
      "Desarrollo de aplicaciones full stack de manera freelance, en especial aplicaciones de escritorio con Java y aplicaciones móviles con React Native para clientes particulares y MIPYMES.",
  },
  {
    company: "Cubo Labs",
    position: "Desarrollador FullStack",
    date: "Noviembre 2025 - Mayo 2026",
    location: "Juigalpa, Nicaragua",
    skills: [
      "React",
      "Context API",
      "Zustand",
      "PostgreSQL",
      "Supabase",
      "Tailwind",
      "Docker",
    ],
    github: [],
    description: `● Diseño y desarrollo de aplicaciones web de alto rendimiento con React.js y TypeScript para crear interfaces dinámicas y responsive.
● Implementación de arquitecturas Serverless utilizando Supabase para la gestión de autenticación y bases de datos en tiempo real.
● Optimización de procesos empresariales mediante la digitalización de flujos de trabajo con arquitecturas desacopladas.`,
  },
  {
    company: "Autonomo",
    position: "Desarrollador Movil - Proyecto de graduacion",
    date: "Mayo 2025 - Diciembre 2025",
    location: "Juigalpa, Nicaragua",
    skills: [
      "Java",
      "Android",
      "Room DB",
      "Retrofit",
      "Gemini Api",
      "Spring Boot",
      "Material Design",
      "Tensor Flow Lite",
    ],
    github: [
      "http://github.com/JeysonhT/AgroSmart",
      "https://github.com/JeysonhT/Spring_Agrosmart_Middleware",
      "https://github.com/JeysonhT/Agrosmart_Colab_NoteBook",
    ],
    description: `● Desarrollo de una solución móvil para agricultura de precisión utilizando Machine Learning para la detección de deficiencias nutricionales.
● Integración de modelos de visión artificial con TensorFlow Lite para procesamiento en el dispositivo (Edge AI).
● Aplicación de Clean Architecture y MVVM para garantizar un código testeable y mantenible.`,
  },
  {
    company: "Autonomo",
    position: "Desarrollador Java Desktop",
    date: "Noviembre 2024 - Diciembre 2024",
    location: "Boaco, Nicaragua",
    skills: ["Java", "Java Swing", "Hibernate", "Mysql", "Jasper Reports"],
    github: ["https://github.com/JeysonhT/InvetarioFarmacia"],
    description: `● Construcción de un sistema de gestión de inventarios para PYMEs utilizando Java con Hibernate para la persistencia de datos.
● Modelado de base de datos relacional en MySQL optimizada para consultas transaccionales.
● Implementación del patrón MVC, separando la lógica de negocio de la interfaz de usuario.`,
  },
];

const formatDescription = (desc: string) => {
  const points = desc
    .split(/●|\n/)
    .map((p) => p.trim())
    .filter((p) => p.length > 0);

  if (points.length <= 1) {
    return [desc];
  }
  return points;
};
---

<section id="experience" class="py-16">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    
    <!-- Section Header -->
    <div class="mb-16">
      <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6 tracking-tight">
        Experiencia Profesional
      </h2>
      <div class="w-24 h-2 bg-indigo-600 rounded-full mb-8"></div>
      <p class="text-gray-500 text-xl max-w-2xl leading-relaxed">
        Mi trayectoria como desarrollador, construyendo soluciones web, móviles y de escritorio para diversas necesidades.
      </p>
    </div>

    <!-- UNIFIED VERTICAL TIMELINE -->
    <div class="relative max-w-8xl mx-auto">
      
      <!-- Main Vertical Connecting Line -->
      <div class="absolute left-6 md:left-8 top-4 bottom-4 w-0.5 bg-indigo-100 -z-10"></div>

      <div class="space-y-12">
        {
          experiences.map((item) => (
            <div class="relative pl-14 md:pl-20 group">
              
              <!-- Icon/Marker Node -->
              <div class="absolute left-2 md:left-4 top-0.5 w-8 h-8 md:w-9 md:h-9 rounded-full bg-indigo-50 border-2 border-indigo-600 flex items-center justify-center text-indigo-600 z-10 shadow-sm group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300 group-hover:scale-110">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>

              <!-- Detail Card -->
              <div class="bg-white p-6 md:p-8 rounded-2xl border border-gray-100 shadow-sm group-hover:shadow-md group-hover:border-indigo-150 group-hover:-translate-y-1 transition-all duration-300">
                
                <!-- Internal layout: 2-column grid on desktop (lg), 1-column on mobile/tablet -->
                <div class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-6 lg:gap-8">
                  
                  <!-- Left column: Metadata -->
                  <div class="flex flex-col items-start">
                    <!-- Date Badge -->
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-indigo-50/75 text-indigo-700 mb-3">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      {item.date}
                    </span>

                    <!-- Position -->
                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors duration-300 leading-snug">
                      {item.position}
                    </h3>

                    <!-- Company & Location -->
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-semibold text-gray-500 mt-1">
                      <span class="text-gray-800 font-bold">{item.company}</span>
                      <span class="flex items-center gap-1 font-normal text-gray-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        {item.location}
                      </span>
                    </div>
                  </div>

                  <!-- Right column: Description & Details -->
                  <div class="flex flex-col justify-between">
                    <!-- Description Points -->
                    <div class="mb-6">
                      <ul class="space-y-2.5 list-none">
                        {formatDescription(item.description).map((point) => (
                          <li class="text-sm text-gray-600 flex items-start gap-2 leading-relaxed">
                            <span class="text-indigo-600 mt-1.5 select-none text-[8px] shrink-0">●</span>
                            <span>{point}</span>
                          </li>
                        ))}
                      </ul>
                    </div>

                    <!-- Repositories and Tech Badges -->
                    <div class="space-y-4 pt-4 border-t border-gray-50">
                      
                      <!-- Github Links -->
                      {item.github && item.github.length > 0 && (
                        <div class="flex flex-col gap-1.5">
                          <span class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">Repositorios relacionados:</span>
                          <div class="flex flex-wrap gap-2">
                            {item.github.map((url) => {
                              const repoName = url.split("/").pop();
                              return (
                                <a 
                                  href={url} 
                                  target="_blank" 
                                  rel="noopener noreferrer" 
                                  class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg border border-gray-100 bg-gray-50 text-[11px] text-gray-600 hover:text-indigo-600 hover:border-indigo-150 hover:bg-indigo-50/50 transition-all duration-300 font-medium"
                                >
                                  <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
                                  </svg>
                                  {repoName}
                                </a>
                              );
                            })}
                          </div>
                        </div>
                      )}

                      <!-- Technologies used -->
                      <div>
                        <span class="text-[10px] uppercase font-bold text-gray-400 tracking-wider block mb-2">Tecnologías:</span>
                        <div class="flex flex-wrap gap-1.5">
                          {item.skills.map((skill) => (
                            <span class="text-[11px] font-semibold bg-gray-50 text-gray-600 px-2.5 py-0.5 rounded border border-gray-100 hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-100 transition-colors duration-200">
                              {skill}
                            </span>
                          ))}
                        </div>
                      </div>

                    </div>
                  </div>

                </div>

              </div>

            </div>
          ))
        }
      </div>

    </div>

  </div>
</section>
