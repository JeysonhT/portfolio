---
import portfolioIcon from "../assets/portfolioIcons.svg";

const links = [
  { name: "Sobre mi", href: "#about" },
  {
    name: "Mis Habilidades",
    href: "#skills",
  },
  {
    name: "Proyectos",
    href: "#projects",
  },
];
---

<header
  class="bg-white/80 backdrop-blur-md border-b border-gray-100/50 sticky top-0 z-50 font-roboto transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-4 md:px-8 py-2">
    <div class="flex justify-between items-center">
      <div class="shrink-0 flex items-center">
        <a
          href="/"
          class="text-2xl font-bold text-gray-900 hover:text-indigo-600 transition-colors duration-300 tracking-tight flex items-center gap-2"
        >
          <img src={portfolioIcon.src} alt="Logo" class="w-10 h-10" />
          <span>Jeysonh<span class="text-indigo-600">Dev</span></span>
        </a>
      </div>

      <ul class="hidden md:flex gap-8 items-center">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-600 hover:text-indigo-600 font-medium transition-all duration-300 py-2 relative group"
              >
                {link.name}
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-indigo-600 transition-all duration-300 group-hover:w-full" />
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="#contact"
            class="bg-indigo-600 text-white px-5 py-2 rounded-full font-medium hover:bg-indigo-700 transition-all duration-300 shadow-sm hover:shadow-indigo-200"
          >
            Hablemos
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>
